_DEFAULT_MODEL_OTHER = "gpt-4o"

# Path to kilo config file
_KILO_CONFIG_PATH = Path.home() / ".config" / "kilo" / "kilo.jsonc"


_MAX_DIFF_CHARS_DEFAULT = 60_000
_MAX_DIFF_CHARS_ESCALATED = 400_000

# Hunk-aware diff truncation helper

# Binary and generated file skipping

# Patterns for generated files to skip. Adjust as needed.
_GENERATED_FILE_GLOBS = [
    "*.pb.cc",
    "*.pb.h",
    "*.gen.cpp",
    "*.gen.hpp",
    "*.generated.cpp",
    "*.generated.h",
]


# ---------------------------------------------------------------------------
# Kilo config functions
# ---------------------------------------------------------------------------


def _load_kilo_config() -> dict:
    """Load and parse the kilo configuration file.

    Returns a dict with 'disabled_providers' and 'provider' keys.
    'provider' maps provider names to provider configs, each containing a 'models' dict.
    """
    if not _KILO_CONFIG_PATH.exists():
        return {"disabled_providers": [], "provider": {}}
    try:
        # Use json.loads after removing comments (kilo.jsonc supports comments)
        content = _KILO_CONFIG_PATH.read_text(encoding="utf-8")
        # A simple state-based scanner to remove comments while preserving strings.
        cleaned = []
        in_string = False
        string_char = ""
        escaped = False
        i = 0
        while i < len(content):
            char = content[i]
            if escaped:
                cleaned.append(char)
                escaped = False
                i += 1
                continue
            if char == "\\":
                cleaned.append(char)
                escaped = True
                i += 1
                continue
            if in_string:
                if char == string_char:
                    in_string = False
                cleaned.append(char)
            else:
                if char in ('"', "'"):
                    in_string = True
                    string_char = char
                    cleaned.append(char)
                elif content.startswith("//", i):
                    # Find end of line
                    eol = content.find("\n", i)
                    if eol != -1:
                        cleaned.append("\n")
                        i = eol
                    else:
                        i = len(content)
                elif content.startswith("/*", i):
                    # Find end of block comment
                    end = content.find("*/", i + 2)
                    if end == -1:
                        i = len(content)
                    else:
                        i = end + 1
                else:
                    cleaned.append(char)
            i += 1
        return json.loads("".join(cleaned))
    except (OSError, json.JSONDecodeError):
        return {"disabled_providers": [], "provider": {}}


def _load_kilo_config_with_models() -> dict[str, dict[str, str]]:
    """Load kilo config and return a mapping of provider names to model dicts.

    Returns a dict mapping Kilo config provider names to dicts of model keys.
    For example: {"fnal-ow": {"qwen/qwen3-coder-next": {...}, ...}}
    """
    config = _load_kilo_config()
    disabled = set(config.get("disabled_providers", []))
    provider_config = config.get("provider", {})
    mapping: dict[str, dict[str, str]] = {}

    for provider_name, provider_data in provider_config.items():
        if provider_name in disabled or not isinstance(provider_data, dict):
            continue
        models = provider_data.get("models", {})
        if not isinstance(models, dict):
            continue
        mapping[provider_name] = models

    return mapping


def _get_kilo_provider_names() -> list[str]:
    """Return the list of known Kilo config provider names."""
    config = _load_kilo_config()
    disabled = set(config.get("disabled_providers", []))
    provider_config = config.get("provider", {})
    return [name for name in provider_config.keys() if name not in disabled]


def _resolve_kilo_model(model: str) -> str:
    """Resolve a kilo model name, adding provider prefix if needed.

    Logic:
    1. If model contains "/" (e.g., "qwen/"), check if the prefix is a known
       provider in the Kilo config.
    2a. If the prefix IS a known provider, the model is passed to kilo as-is.
    2b. If the prefix is NOT a known provider, the full model (including prefix)
        is treated as the model name and looked up in the config.
    3. If model has no prefix, it is looked up directly in the config.
    4. If the lookup is ambiguous (multiple providers have the model), raise an error.

    Returns the fully-qualified model name in format "provider/model".
    Raises _Error if the model lookup is ambiguous.
    """
    provider_models = _load_kilo_config_with_models()
    known_providers = set(_get_kilo_provider_names())

    # If no model is provided, use the default
    if not model:
        return _DEFAULT_MODEL_KILO

    # If model has a prefix (contains "/"), check if it's a known provider
    if "/" in model:
        prefix, rest = model.split("/", 1)
        if prefix in known_providers:
            # The prefix is a known provider - pass model as-is to kilo
            return model

        # The prefix is NOT a known provider - treat full model as model name
        # and look it up in config
        candidate_providers = []
        for provider_name, models in provider_models.items():
            if model in models:
                candidate_providers.append(provider_name)

        if len(candidate_providers) == 0:
            # Model not found in config; return as-is
            return model
        elif len(candidate_providers) == 1:
            # Unambiguous lookup
            return f"{candidate_providers[0]}/{model}"
        else:
            # Ambiguous lookup - raise error with available providers
            raise _Error(
                f"Model '{model}' is ambiguous: found under providers "
                f"{', '.join(candidate_providers)}. "
                "Please disambiguate by specifying one of these providers as a prefix."
            )

    # Model has no prefix - look it up directly in config
    candidate_providers = []
    candidate_full_names: dict[str, str] = {}  # provider -> full_name

    for provider_name, models in provider_models.items():
        for full_name in models.keys():
            # Extract short name (after first "/")
            if "/" in full_name:
                short_name = full_name.split("/", 1)[1]
            else:
                short_name = full_name

            if short_name == model:
                candidate_providers.append(provider_name)
                candidate_full_names[provider_name] = full_name

    if len(candidate_providers) == 0:
        # Model not found in config; return as-is
        return model
    elif len(candidate_providers) == 1:
        # Unambiguous lookup
        return f"{candidate_providers[0]}/{candidate_full_names[candidate_providers[0]]}"
    else:
        # Ambiguous lookup - raise error with available providers
        raise _Error(
            f"Model '{model}' is ambiguous: found under providers "
            f"{', '.join(candidate_providers)}. "
            "Please disambiguate by specifying one of these providers as a prefix."
        )


def _skip_binary_and_generated(diff: str) -> str:
    """Replace binary and generated file sections in *diff* with a placeholder note.

    Binary sections are lines containing "Binary files ... differ".
    Generated files are detected via filename patterns in the "diff --git" header.
    The placeholder format is ``"[skipped binary/generated file: <path>]"``.
    """
    import fnmatch

    # Split diff into sections starting with "diff --git".
    sections = re.split(r"(?=^diff --git )", diff, flags=re.MULTILINE)
    kept_sections: list[str] = []
    for sec in sections:
        if not sec.strip():
            continue
        # Binary detection.
        m = re.search(r"^Binary files ([^ \n]+) and ([^ \n]+) differ$", sec, flags=re.MULTILINE)
        if m:
            # Extract path from the line, e.g., "Binary files a/foo.bin and b/foo.bin differ"
            path = m.group(2)
            kept_sections.append(f"[skipped binary/generated file: {path}]\n")
            continue
        # Generated file detection via header line.
        header_match = re.search(r"^diff --git a/([^ \n]+) b/([^ \n]+)", sec, flags=re.MULTILINE)
        if header_match:
            path = header_match.group(2)
            if any(fnmatch.fnmatch(path, pat) for pat in _GENERATED_FILE_GLOBS):
                kept_sections.append(f"[skipped binary/generated file: {path}]\n")
                continue
        # Keep original section.
        kept_sections.append(sec)
    return "".join(kept_sections)


def _truncate_diff(diff: str, max_chars: int) -> str:
    r"""Truncate *diff* to *max_chars* preserving the diffstat and whole file hunks.

    - If the diff length is within the budget, return unchanged.
    - Preserve the leading "git diff --cached --stat -p" stat block (the lines before the first
      "diff --git").
    - Include full ``diff --git`` file sections until adding the next section would exceed
      *max_chars*.
    - If a single file section alone exceeds *max_chars*, fall back to cutting at a line boundary
      within that section.
    - Omitted sections are replaced with a note:
      ``"\n\n[diff truncated: N of M files omitted to fit context budget]"``.
    """
    if len(diff) <= max_chars:
        return diff

    # Split the diff into stat block + individual file sections.
    # Use a zero-width lookahead so each file section retains its "diff --git " prefix.
    raw_sections = re.split(r"(?=^diff --git )", diff, flags=re.MULTILINE)
    # First element is the leading diffstat block (may be empty for a bare diff).
    stat_block = raw_sections[0]
    file_sections = raw_sections[1:]  # each starts with "diff --git "

    total_files = len(file_sections)
    kept_sections: list[str] = []
    current_len = len(stat_block)

    line_boundary_cut = False  # True when a section was cut mid-file
    for sec in file_sections:
        if current_len + len(sec) <= max_chars:
            kept_sections.append(sec)
            current_len += len(sec)
        else:
            # Hard enforcement: if the remaining budget is too small for this section,
            # we check if we can fit at least some of it.
            remaining_budget = max_chars - current_len
            if remaining_budget > 0:
                # Fall back to a line-boundary cut within this section.
                lines = sec.splitlines(keepends=True)
                acc = ""
                for line in lines:
                    if len(acc) + len(line) > remaining_budget:
                        break
                    acc += line
                if acc:
                    kept_sections.append(acc)
                line_boundary_cut = True
            break

    omitted = total_files - len(kept_sections)
    final = stat_block + "".join(kept_sections)
    if line_boundary_cut:
        final += (
            f"\n\n[diff truncated: section cut mid-file; "
            f"{omitted} of {total_files} files omitted to fit context budget]"
        )
    elif omitted:
        final += (
            f"\n\n[diff truncated: {omitted} of {total_files} files omitted to fit context budget]"
        )
    return final


_SYSTEM = textwrap.dedent("""\
    You are an expert software developer writing Git commit messages.

    CRITICAL — respond with ONLY one single version of the commit message, nothing else.
    - Do NOT provide multiple options or candidates.
    - Do NOT repeat or duplicate the commit message.
    - Do NOT return both a "long" and "short" version of the same message.
    - If you write the commit message, write it ONCE and only once.
    - No preamble, commentary, or markdown fences.
    - Your very first character must be the first character of the subject line.

    ## Conventional Commits v1.0.0 Guidelines
    Specification: https://www.conventionalcommits.org/en/v1.0.0/

    Format: <type>[optional scope][optional !]: <description>
    [optional body]
    [optional footer(s)]

    - Common types (spec allows additional types): feat, fix, docs, style, refactor,
      perf, test, build, ci, chore, revert
    - Breaking changes: append '!' directly before ':' (e.g., `feat!:`) OR add
      `BREAKING CHANGE: <description>` as a footer line
    - Subject: imperative mood, no trailing period, keep it brief
    - Body: Explain *what* changed and *why* (motivation, problem, tradeoffs).
      Required only for non-trivial changes. Body and footer each separated from
      subject/footer by a blank line.
    - Footer format: `Token: value` or `Token# value` (tokens use hyphens instead
      of spaces, except BREAKING CHANGE which may use spaces)
    - Use bullet points for lists; avoid decorative formatting
    - Do NOT reproduce the diff verbatim or enumerate every changed file
""")

# ---------------------------------------------------------------------------
# Errors
# ---------------------------------------------------------------------------


class _Error(Exception):
    """Base error for git-ai-commit."""


class _APIError(_Error):
    """An error returned by a remote API."""

    def __init__(self, msg: str, status: int = 0) -> None:
        super().__init__(msg)
        self.status = status


# ---------------------------------------------------------------------------
# Git helpers
# ---------------------------------------------------------------------------


def _git(*args: str) -> str:
    result = subprocess.run(
        ["git", *args],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        raise _Error(f"`git {' '.join(args)}` failed:\n{result.stderr.strip()}")
    return result.stdout


def _git_config(key: str) -> str:
    try:
        return _git("config", "--get", key).strip()
    except _Error:
        return ""


def _git_root() -> Path:
    return Path(_git("rev-parse", "--show-toplevel").strip())


def _staged_diff(amend: bool = False) -> str:
    if amend:
        try:
            # Diff the index against HEAD^, showing what the amended commit
            # will contain relative to its grandparent.
            return _git("diff", "--cached", "--stat", "-p", "HEAD^")
        except _Error:
            # Fallback: first commit in the repo has no HEAD^.
            return _git("diff", "--cached", "--stat", "-p")
    return _git("diff", "--cached", "--stat", "-p")


def _status() -> str:
    return _git("status", "--short")


def _recent_log() -> str:
    # Depth deliberately capped at 5 to keep context concise.
    # Increase via a future --history-depth flag if needed.
    try:
        return _git("log", "--oneline", "-5")
    except _Error:
        return "(no prior commits)"


def _last_commit_message() -> str:
    try:
        return _git("log", "-1", "--pretty=%B").strip()
    except _Error:
        return ""


def _read_dir_md(path: Path) -> str:
    """Read all Markdown files in *path* and concatenate them."""
    if not path.is_dir():
        return ""
    parts: list[str] = []
    try:
        items = sorted(path.glob("*.md"))
    except OSError:
        return ""  # directory listing failed; nothing to include
    for item in items:
        if item.is_file():
            try:
                content = item.read_text().strip()
            except OSError:
                continue  # file disappeared or is unreadable; skip it
            if content:
                parts.append(f"#### {item.name}\n\n{content}")
    return "\n\n".join(parts)


def _get_instructions(root: Path) -> str:
    """Read user-level and repository-level instructions from various AI tools.

    Only procedural/communications-oriented files are included — those that
    tell the model *how* to write a commit message (conventions, style, PR
    process).  Technical reference files such as DEVELOPING.md and
    CLANG_TIDY_CONFIGURATION.md are intentionally excluded; any technical
    context the model needs should come from the diff itself or be supplied
    via --context.

    When an AGENTS.md (or AGENT.md) file is present and non-empty it is
    treated as the authoritative summary of all project instructions.  In
    that case the tool-specific rule directories (.kilo/, .kiro/, .amazonq/,
    .kilocode/, .gemini/) and .github/copilot-instructions.md are skipped to
    avoid sending thousands of redundant tokens.
    """
    user_candidates = [
        Path.home() / ".config" / "git-ai-commit" / "instructions.md",
        Path.home() / ".config" / "copilot" / "instructions.md",
    ]
    # Repository-level file candidates.  Both AGENTS.md and AGENT.md are
    # checked to support projects using either convention.
    agents_files = [root / "AGENTS.md", root / "AGENT.md"]
    # Procedural/communications files only — no technical reference docs.
    # DEVELOPING.md and CLANG_TIDY_CONFIGURATION.md are excluded: any
    # relevant technical context should come from the diff or --context.
    repo_files_extra = [
        root / "GEMINI.md",
        root / "CLAUDE.md",
        root / "CONTEXT.md",
        root / "INSTRUCTIONS.md",
        root / "CONTRIBUTING.md",
        root / "HACKING.md",
        root / "ARCHITECTURE.md",
        root / "STYLEGUIDE.md",
        root / ".cursorrules",
        root / ".clinerules",
        root / ".windsurfrules",
        root / "q.rules",
        root / ".kilocoderules",
        root / ".gemini-rules",
    ]
    # Tool-specific instruction files/directories.  These are skipped when an
    # AGENTS.md is present, since AGENTS.md is intended to synthesise them.
    tool_files = [
        root / ".github" / "copilot-instructions.md",
    ]
    # Both .kiro/rules/ (this project's layout) and .kiro/steering/ (used in
    # some other projects) are checked.  .kilo/agent/ and .kilo/command/ cover
    # projects using the modern Kilo config layout without a top-level AGENTS.md.
    tool_dirs = [
        root / ".amazonq" / "rules",
        root / ".amazonq" / "rules" / "memory-bank",
        root / ".kiro" / "rules",
        root / ".kiro" / "steering",
        root / ".gemini" / "rules",
        root / ".kilocode",
        root / ".kilo" / "agent",
        root / ".kilo" / "command",
    ]

    # Determine whether an AGENTS.md / AGENT.md is present and non-empty.
    # If so, skip the redundant tool-specific sources.
    has_agents_file = any(p.is_file() and p.stat().st_size > 0 for p in agents_files)
    repo_files = agents_files + repo_files_extra
    if not has_agents_file:
        repo_files = repo_files + tool_files
    repo_dirs = [] if has_agents_file else tool_dirs

    instructions: list[str] = []

    for path in user_candidates:
        if path.is_file():
            try:
                content = path.read_text().strip()
                if content:
                    instructions.append(f"### User-level instructions ({path})\n\n{content}")
            except OSError:
                continue  # file unreadable; skip to next candidate

    for path in repo_files:
        if path.is_file():
            try:
                content = path.read_text().strip()
                if content:
                    instructions.append(f"### Repository instructions ({path.name})\n\n{content}")
            except OSError:
                continue  # file unreadable; skip to next candidate

    for path in repo_dirs:
        if path.is_dir():
            content = _read_dir_md(path)
            if content:
                rel = path.relative_to(root)
                instructions.append(f"### Repository instructions (from {rel}/)\n\n{content}")

    if template_path := _git_config("commit.template"):
        try:
            full_path = Path(os.path.expanduser(template_path))
            if not full_path.is_absolute():
                full_path = root / full_path
            content = full_path.read_text(encoding="utf-8").strip() if full_path.is_file() else ""
        except OSError:
            content = ""  # commit template unreadable; skip it
        if content:
            instructions.append(f"### Git commit template ({template_path})\n\n{content}")

    return "\n\n".join(instructions)


# ---------------------------------------------------------------------------
# Token resolution
# ---------------------------------------------------------------------------


def _max_tokens_for_prompt(prompt_size: int, model: str) -> int:
    """Return max_tokens based on prompt size and model capabilities.

    Reasoning models (e.g., qwen/qwen3-coder-next, google/gemma4-31b)
    spend significant internal thinking tokens before producing visible
    output. A low max_tokens budget can cause them to return empty content
    (finish_reason=stop with zero visible text) instead of an error.

    The max_tokens budget must be large enough for:
    - System prompt
    - User prompt (diff, status, log, instructions, context)
    - Expected output (commit message with subject + body)

    For large prompts, increase max_tokens to avoid truncating the response.
    This applies to all models, not just reasoning ones.
    """
    # Base budget: enough for a decent commit message (subject + body)
    base_tokens = 2048

    # Reasoning models need higher budget to avoid empty responses
    if model:
        model_lower = model.lower()
        if any(kw in model_lower for kw in ("reasoning", "4-5", "qwen3-coder-next", "gemma4-31b")):
            return 8192

    # Scale with prompt size to avoid truncated responses
    if prompt_size > 50_000:
        return 4096
    elif prompt_size > 25_000:
        return 3072
    else:
        return base_tokens


def _gh_config_token() -> str | None:
    """Read the first oauth_token from ~/.config/gh/hosts.yml."""
    hosts = Path.home() / ".config" / "gh" / "hosts.yml"
    if not hosts.exists():
        return None
    try:
        m = re.search(r"oauth_token:\s*(\S+)", hosts.read_text())
        return m.group(1) if m else None
    except OSError:
        return None


def _gh_cli_token() -> str | None:
    """Obtain a token via `gh auth token`, if gh is installed and logged in."""
    try:
        r = subprocess.run(
            ["gh", "auth", "token"],
            capture_output=True,
            text=True,
            check=False,
        )
        if r.returncode == 0 and r.stdout.strip():
            return r.stdout.strip()
    except FileNotFoundError:
        return None  # gh is not installed; no token available
    return None


def _gh_oauth_token() -> str | None:
    """Return a GitHub OAuth token from env vars, gh CLI, or hosts file.

    This deliberately ignores GIT_AI_COMMIT_TOKEN because that variable may
    hold a non-GitHub key (e.g. a LiteLLM API key).  Used when a genuine
    GitHub OAuth token is required, such as the Copilot token exchange.
    """
    for var in ("GITHUB_TOKEN", "GH_TOKEN"):
        if val := os.environ.get(var, "").strip():
            return val
    if tok := _gh_cli_token():
        return tok
    return _gh_config_token()


def _token(backend: str, model: str = "") -> str:
    """Resolve the best available API token for the given backend and model."""
    # GIT_AI_COMMIT_TOKEN always wins regardless of backend.
    if val := os.environ.get("GIT_AI_COMMIT_TOKEN", "").strip():
        return val

    if backend == "kilo":
        # For the kilo backend, only use GIT_AI_COMMIT_TOKEN.
        # No fallback to GITHUB_TOKEN, GH_TOKEN, gh CLI, or hosts.yml.
        # If no token is set, return empty string - let the API handle it.
        return ""

    for var in ("GITHUB_TOKEN", "GH_TOKEN"):
        if val := os.environ.get(var, "").strip():
            return val

    if tok := _gh_cli_token():
        return tok

    # Last resort: parse the gh hosts file directly (works in read-only
    # Codespace FS where `gh auth token` errors on write).
    if tok := _gh_config_token():
        return tok

    raise _Error(
        "No API token found. Set GIT_AI_COMMIT_TOKEN, GITHUB_TOKEN, or run 'gh auth login'."
    )


# ---------------------------------------------------------------------------
# Response cleaning
# ---------------------------------------------------------------------------


def _clean_message(text: str) -> str:
    r"""Strip model preamble and fenced code blocks from a raw API response.

    Also handles the common case where the AI returns two versions of the commit
    message (e.g., a longer version followed by a shorter duplicate), or returns
    the same message consecutively.
    """
    # 1. Extract all fenced code blocks (if any) and concatenate them.
    fences = re.findall(r"```[^\n]*\n(.*?)```", text, re.DOTALL)
    if fences:
        # Join the contents of all fenced blocks preserving their order.
        # Strip surrounding whitespace from each block before joining.
        text = "\n".join(block.strip() for block in fences)
    else:
        # No fenced blocks – fall back to stripping lone fence markers.
        # Strip trailing lone fence (e.g. "\n```text\n")
        text = re.sub(r"\n```[^\n]*\s*\Z", "", text)
        # Strip leading lone fence (e.g. "```text\n")
        text = re.sub(r"\A```[^\n]*\n", "", text)

    # 2. Strip leading prose preamble (now using the safer splitlines version)
    if not re.match(r"^[a-z]+(?:\([^)]+\))?!?:\s", text):
        # Try to remove preamble that ends with a colon and double newline
        text = re.sub(r"\A.*?:\s*\n\s*\n", "", text, count=1, flags=re.DOTALL)

        # If that didn't result in a Conventional Commit format, try more
        # aggressive preamble removal
        if not re.match(r"^[a-z]+(?:\([^)]+\))?!?:\s", text):
            lines = text.splitlines()
            if lines:
                first_line = lines[0].strip()
                if len(first_line) > 72 or re.match(
                    r"^(?:The |This |These |I |Here |Note:|Below|Above|A |An )", first_line
                ):
                    # If the first line looks like preamble, remove everything
                    # until the first double newline
                    remainder = re.sub(r"\A.*?\n\s*\n", "", text, count=1, flags=re.DOTALL)
                    if remainder.strip():
                        text = remainder
                    else:
                        # If nothing is left after removing preamble, the whole text was preamble
                        text = ""

                    # Final check: if the resulting text still looks like preamble
                    # (e.g. single line without CC format) and we just did a remainder
                    # sub that might have left a trailing line
                    if text.strip() and not re.match(r"^[a-z]+(?:\([^)]+\))?!?:\s", text.strip()):
                        # If it's just one line and matches preamble patterns, clear it
                        if len(text.splitlines()) <= 1 and re.match(
                            r"^(?:The |This |These |I |Here |Note:|Below|Above|A |An )",
                            text.strip(),
                        ):
                            text = ""

    # 3. Remove repeated content - now that preamble is stripped
    cleaned = text.strip()

    # Early exit for empty result
    if not cleaned:
        return ""

    # Apply deduplication until no more changes occur
    # This handles cases where the message appears multiple times (2x, 3x, etc.)
    prev_cleaned = None
    while prev_cleaned != cleaned:
        prev_cleaned = cleaned
        cleaned = _deduplicate_once(cleaned)
        if not cleaned:
            return ""

    return cleaned


def _deduplicate_once(text: str) -> str:
    """Perform a single deduplication pass on text.

    Returns the text with duplicates removed. If no duplicates are found,
    returns the original text.
    """
    # Case 1: two identical sections separated by double newline – keep first
    sections = text.split("\n\n", 1)
    if len(sections) == 2 and sections[0].strip() == sections[1].strip():
        return sections[0].strip()

    # Case 2: Handle duplicate messages where section 2 contains section 1's content
    # (with possible modification or truncation)
    if len(sections) == 2:
        sec1 = sections[0].strip()
        sec2 = sections[1].strip()
        sec1_lines = sec1.splitlines()
        sec2_lines = sec2.splitlines()
        if sec1_lines and sec2_lines:
            sec1_subject = sec1_lines[0].strip()

            # Check if section 1's subject appears in section 2
            # If so, section 2 may contain duplicate content
            duplicate_subject_idx = None
            for i, line in enumerate(sec2_lines):
                if line.strip() == sec1_subject:
                    duplicate_subject_idx = i
                    break

            if duplicate_subject_idx is not None:
                # The subject line from section 1 appears in section 2
                # Keep only the part of section 2 before the duplicate subject
                body_before_duplicate = sec2_lines[:duplicate_subject_idx]
                if body_before_duplicate:
                    # Keep section 1 + body from section 2 (before duplicate)
                    return sec1 + "\n\n" + "\n".join(body_before_duplicate).strip()
                else:
                    # Section 2 starts with the subject - just return section 1
                    return sec1

            # Check if section 2's first line matches section 1's subject
            sec2_subject = sec2_lines[0].strip()
            if sec1_subject == sec2_subject:
                len_sec1 = len(sec1_lines)
                len_sec2 = len(sec2_lines)
                if len_sec2 <= len_sec1:
                    # Check if sec2 is essentially sec1 (maybe slightly different)
                    matching_lines = sum(
                        1 for l1, l2 in zip(sec1_lines, sec2_lines, strict=True) if l1 == l2
                    )
                    if matching_lines >= len(sec2_lines) * 0.8:  # 80% match threshold
                        return sec1
                    elif (
                        matching_lines >= len(sec1_lines) * 0.8
                    ):  # 80% match threshold (sec1 is shorter)
                        return sec2

    # Case 3: Check for repeated subject patterns across sections
    # Use the subject-based deduplicator
    cleaned = _remove_duplicate_paragraphs_with_subject(text)
    return cleaned


def _remove_duplicate_paragraphs_with_subject(text: str) -> str:
    """Remove duplicate or near-duplicate content based on subject lines.

    If multiple paragraphs start with the same subject line pattern
    (e.g., 'refactor(scripts): ...'), keep only the first and longest one.
    """
    paragraphs = text.split("\n\n")
    if len(paragraphs) <= 1:
        return text

    # Extract subject from each paragraph
    subjects: dict[int, str] = {}  # index -> raw subject line
    for i, para in enumerate(paragraphs):
        lines = para.strip().splitlines()
        if lines:
            subjects[i] = lines[0].strip()

    # Find and remove duplicate subjects (keep first/longest)
    seen_subjects: dict[str, int] = {}  # subject -> first index seen
    to_keep: list[int] = []
    for i, para in enumerate(paragraphs):
        if i not in subjects:
            to_keep.append(i)
            continue
        subject = subjects[i]
        if subject not in seen_subjects:
            seen_subjects[subject] = i
            to_keep.append(i)
        else:
            # Subject already seen - check if this one is longer
            existing_idx = seen_subjects[subject]
            existing_len = len(paragraphs[existing_idx])
            current_len = len(para)
            if current_len > existing_len:
                # This one is longer, replace the existing one
                to_keep = [j for j in to_keep if j != existing_idx]
                seen_subjects[subject] = i
                to_keep.append(i)
            # Otherwise skip this one (it's a shorter duplicate)

    return "\n\n".join(paragraphs[i].strip() for i in sorted(to_keep) if paragraphs[i].strip())


# ---------------------------------------------------------------------------
# AI API
# ---------------------------------------------------------------------------


def _copilot_token(oauth: str) -> str:
    """Exchange a GitHub OAuth token for a short-lived Copilot token."""
    req = urllib.request.Request(
        _COPILOT_TOKEN_URL,
        headers={
            "Authorization": f"token {oauth}",
            "Accept": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            return json.loads(resp.read())["token"]
    except urllib.error.HTTPError as exc:
        body = exc.read().decode(errors="replace")
        raise _APIError(f"Copilot token exchange failed (HTTP {exc.code}): {body[:300]}") from exc
    except (urllib.error.URLError, KeyError, json.JSONDecodeError) as exc:
        raise _APIError(f"Copilot token exchange failed: {exc}") from exc


def _chat_kilo(model: str, messages: list[dict[str, str]], token: str, api_base: str) -> str:
    """Send *messages* via the kilo CLI and return the reply.

    The kilo backend always uses --agent=code and resolves model names
    against the kilo config to add provider prefixes if needed.
    """
    # Build the prompt from messages
    system_content = ""
    user_content = ""
    for m in messages:
        if m["role"] == "system":
            system_content = m["content"]
        elif m["role"] == "user":
            user_content = m["content"]

    if system_content:
        prompt = f"System Instructions:\n{system_content}\n\n{user_content}"
    else:
        prompt = user_content

    # Resolve model name against kilo config (add provider prefix if needed)
    resolved_model = _resolve_kilo_model(model or _KILO_DEFAULT_MODEL)

    # Build kilo run command with --agent=code
    cmd = ["kilo", "run", "--agent=code"]
    if resolved_model:
        cmd += ["-m", resolved_model]

    # Use environment variables for authentication and API URL
    env = os.environ.copy()
    if token:
        # Clear KILO_SERVER_PASSWORD if we are setting it from GIT_AI_COMMIT_TOKEN
        # to ensure the tool's preferred token takes precedence.
        env["KILO_SERVER_PASSWORD"] = token
    if api_base:
        env["KILO_SERVER_URL"] = api_base

    try:
        result = subprocess.run(
            cmd,
            input=prompt,
            capture_output=True,
            text=True,
            check=False,
            timeout=60,
            env=env,
        )
    except subprocess.TimeoutExpired as exc:
        raise _APIError("kilo run timed out after 60 seconds.", status=0) from exc
    except FileNotFoundError as exc:
        raise _Error("kilo CLI not found in PATH. Ensure it is installed and available.") from exc

    if result.returncode != 0:
        raise _APIError(
            (f"kilo run failed (exit code {result.returncode}):\n{result.stderr.strip()}"),
            result.returncode,
        )

    return _clean_message(result.stdout)


def _chat(
    token: str,
    api_base: str,
    model: str,
    messages: list[dict[str, str]],
    backend: str = "kilo",
) -> str:
    """Send *messages* to the chat completions endpoint and return the reply."""
    # Scale max_tokens with prompt size to avoid truncated responses.
    # This applies to all models, not just reasoning ones.
    prompt_size = sum(len(m["content"]) for m in messages)
    max_tokens = _max_tokens_for_prompt(prompt_size, model)

    # Use kilo CLI for the kilo backend
    if backend == "kilo":
        return _chat_kilo(model, messages, token, api_base)

    payload = json.dumps(
        {
            "model": model,
            "messages": messages,
            "temperature": 0.2,
            "max_tokens": max_tokens,
        }
    ).encode()
    req = urllib.request.Request(
        f"{api_base}/chat/completions",
        data=payload,
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
            "Accept": "application/json",
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=60) as resp:
            data = json.loads(resp.read())
            raw = data["choices"][0]["message"]["content"]
            return _clean_message(raw)
    except urllib.error.HTTPError as exc:
        body = exc.read().decode(errors="replace")
        raise _APIError(f"HTTP {exc.code}: {body[:500]}", exc.code) from exc
    except urllib.error.URLError as exc:
        raise _APIError(f"Network error: {exc}") from exc
    except (KeyError, IndexError, json.JSONDecodeError) as exc:
        raise _APIError(f"Unexpected API response: {exc}") from exc


def _chat_antigravity(model: str, messages: list[dict[str, str]]) -> str:
    """Send *messages* to the antigravity CLI (agy) and return the reply."""
    system_content = ""
    user_content = ""
    for m in messages:
        if m["role"] == "system":
            system_content = m["content"]
        elif m["role"] == "user":
            user_content = m["content"]

    if system_content:
        prompt = f"System Instructions:\n{system_content}\n\n{user_content}"
    else:
        prompt = user_content

    cmd = ["agy", "-p", "-"]
    if model:
        cmd += ["--model", model]

    try:
        result = subprocess.run(
            cmd,
            input=prompt,
            capture_output=True,
            text=True,
            check=False,
            timeout=60,
        )
    except subprocess.TimeoutExpired as exc:
        raise _APIError("Antigravity CLI (agy) timed out after 60 seconds.", status=0) from exc
    except FileNotFoundError as exc:
        raise _Error(
            "Antigravity CLI (agy) not found in PATH. Ensure it is installed and available."
        ) from exc

    if result.returncode != 0:
        raise _APIError(
            (
                "Antigravity CLI (agy) failed "
                f"(exit code {result.returncode}):\n{result.stderr.strip()}"
            ),
            result.returncode,
        )

    return _clean_message(result.stdout)


# ---------------------------------------------------------------------------
# Prompt construction
# ---------------------------------------------------------------------------


def _build_messages(
    diff: str,
    status: str,
    log: str,
    context: str,
    root: Path,
    last_msg: str = "",
    instr: str = "",
    amend_no_diff: bool = False,
    max_diff_chars: int = _MAX_DIFF_CHARS_DEFAULT,
) -> list[dict[str, str]]:
    """Build the system + user message list for the chat completion request.

    If `amend_no_diff` is True, there are no staged changes; the model should rewrite
    the previous commit message to conform to Conventional Commits guidelines.
    """
    # Apply hunk-aware truncation using the helper.
    diff = _truncate_diff(diff, max_diff_chars)

    parts: list[str] = [
        f"Repository: {root}\n",
        f"## Staged diff (git diff --cached)\n\n```diff\n{diff}\n```",
        f"\n## Status (git status --short)\n\n```\n{status.strip()}\n```",
        f"\n## Recent commits (git log --oneline -5)\n\n```\n{log.strip()}\n```",
    ]
    if last_msg:
        parts.append(f"\n## Previous commit message\n\n```\n{last_msg}\n```")
    if amend_no_diff:
        parts.append(
            "\n## Note\n\nNo staged changes are present. Rewrite the above previous commit "
            "message to follow the Conventional Commits format and improve its wording."
        )
    if instr:
        parts.append(f"\n## Agent instructions\n\n{instr}")
    if context:
        parts.append(f"\n## Supplemental context\n\n{context}")
    if amend_no_diff:
        parts.append(
            "\n\nRewrite the previous commit message to follow Conventional Commits guidelines."
            "  Do not simply repeat it; provide an improved version that complies with the format"
            " and uses clearer wording."
            "  Respond with only the revised commit message, starting with the subject line."
        )
    else:
        parts.append(
            "\n\nWrite the commit message for the staged changes above."
            "  Remember: respond with the commit message text only —"
            " start directly with the subject line."
        )

    return [
        {"role": "system", "content": _SYSTEM},
        {"role": "user", "content": "\n".join(parts)},
    ]


# ---------------------------------------------------------------------------
# Misc helpers
# ---------------------------------------------------------------------------


def _edit(text: str) -> str:
    """Open *text* in $EDITOR and return the edited, comment-stripped result."""
    # Determine which editor to invoke.
    # If stdin is a TTY, prefer $VISUAL, then $EDITOR; otherwise prefer $EDITOR, then $VISUAL.
    if sys.stdin.isatty():
        editor = os.environ.get("VISUAL") or os.environ.get("EDITOR") or "vi"
    else:
        editor = os.environ.get("EDITOR") or os.environ.get("VISUAL") or "vi"
    with tempfile.NamedTemporaryFile(
        mode="w", suffix=".txt", prefix="git-ai-commit-", delete=False
    ) as fh:
        fh.write(text)
        fh.write(
            "\n\n"
            "# ─── Lines starting with '#' are ignored. ───────────────────────\n"
            "# An empty message aborts the commit.\n"
        )
        tmp = Path(fh.name)
    try:
        try:
            subprocess.run([editor, str(tmp)], check=True)
        except FileNotFoundError:
            raise _Error(f"Editor not found: {editor!r}. Set $EDITOR or $VISUAL.") from None
        except subprocess.CalledProcessError as exc:
            raise _Error(f"Editor exited with status {exc.returncode}.") from exc
        try:
            lines = tmp.read_text(encoding="utf-8").splitlines()
        except (OSError, UnicodeDecodeError) as exc:
            raise _Error(f"Could not read editor output: {exc}") from exc
        return "\n".join(line for line in lines if not line.startswith("#")).strip()
    finally:
        tmp.unlink(missing_ok=True)


def _confirm(prompt: str) -> bool:
    """Prompt for y/N, opening /dev/tty if stdin is a pipe."""
    try:
        with contextlib.ExitStack() as stack:
            if sys.stdin.isatty():
                source = sys.stdin
            else:
                # enter_context registers the file's __exit__ on the stack, so
                # the file is closed automatically when the `with` block exits.
                # codeql[py/file-not-closed]
                source = stack.enter_context(open("/dev/tty", encoding="utf-8"))  # noqa: SIM115
            print(f"{prompt} [y/N] ", end="", flush=True)
            reply = source.readline().strip().lower()
            return reply in ("y", "yes")
    except (EOFError, KeyboardInterrupt, OSError):
        print()
        return False


def _print_rule(msg: str, *, file: TextIO = sys.stderr) -> None:
    print(f"\n{'─' * 72}\n{msg}\n{'─' * 72}\n", file=file)


# ---------------------------------------------------------------------------
# Backend resolution
# ---------------------------------------------------------------------------

_BACKENDS = ("kilo", "github-models", "copilot", "antigravity", "agy")


def _resolve_backend_and_api(backend: str, api_override: str) -> tuple[str, str]:
    """Return (backend, api_base) after applying any --api override."""
    if backend in ("antigravity", "agy"):
        return backend, ""
    if api_override:
        return backend, api_override
    if backend == "kilo":
        # For kilo backend, only use API URL if explicitly set via env var.
        # No default URL - user must set GIT_AI_COMMIT_API or use --api.
        return backend, _DEFAULT_KILO_API
    if backend == "copilot":
        return backend, _COPILOT_API_BASE
    return backend, _GITHUB_MODELS_BASE


def _default_model(backend: str) -> str:
    if backend in ("antigravity", "agy"):
        return ""
    return _DEFAULT_MODEL_KILO if backend == "kilo" else _DEFAULT_MODEL_OTHER


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------


def main() -> None:
    """Parse arguments, generate a commit message, and optionally commit."""
    default_backend = os.environ.get("GIT_AI_COMMIT_BACKEND", "kilo")
    if default_backend not in _BACKENDS:
        default_backend = "kilo"

    # Split argv on the first `--` separator.  Everything after `--` is passed
    # verbatim to `git commit` without any interpretation by this script.
    argv = sys.argv[1:]
    if "--" in argv:
        sep = argv.index("--")
        extra_git_args: list[str] = argv[sep + 1 :]
        argv = argv[:sep]
    else:
        extra_git_args = []

    ap = argparse.ArgumentParser(
        prog="git-ai-commit",
        description="Commit staged changes with an AI-generated commit message.",
        epilog=(
            "Supplemental context can be piped on stdin:\n"
            "  echo 'Fixes #42' | git-ai-commit --yes\n\n"
            "Can also be invoked as a Git subcommand:\n"
            "  git ai-commit [OPTIONS]\n\n"
            "Options after -- are forwarded verbatim to git commit:\n"
            "  git ai-commit --yes -- --no-verify --signoff"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    ap.add_argument("--context", metavar="TEXT", help="Supplemental context for the AI")
    ap.add_argument(
        "--backend",
        choices=_BACKENDS,
        default=default_backend,
        help=(
            "API backend to use: kilo (FNAL LiteLLM, default), "
            "github-models, copilot, antigravity, or agy "
            "(env: GIT_AI_COMMIT_BACKEND)"
        ),
    )
    ap.add_argument(
        "--model",
        default=os.environ.get("GIT_AI_COMMIT_MODEL", ""),
        metavar="MODEL",
        help=(
            f"Model name — defaults to {_DEFAULT_MODEL_KILO} for the kilo "
            f"backend and {_DEFAULT_MODEL_OTHER} for others "
            "(env: GIT_AI_COMMIT_MODEL, GIT_AI_COMMIT_KILO_MODEL)"
        ),
    )
    ap.add_argument(
        "--api",
        default=os.environ.get("GIT_AI_COMMIT_API", ""),
        metavar="URL",
        help="Override the API base URL (env: GIT_AI_COMMIT_API)",
    )
    ap.add_argument("--dry-run", action="store_true", help="Print message; do not commit")
    ap.add_argument("--amend", action="store_true", help="Amend the previous commit")
    ap.add_argument("-y", "--yes", action="store_true", help="Skip confirmation prompt")
    ap.add_argument("-e", "--edit", action="store_true", help="Open message in $EDITOR")
    ap.add_argument(
        "--no-instructions",
        action="store_true",
        help="Skip all instruction/context files; send only the diff, status, and log",
    )
    args = ap.parse_args(argv)

    backend, api_base = _resolve_backend_and_api(args.backend, args.api)
    # Collect supplemental context from --context and/or stdin.
    ctx_parts: list[str] = []
    if args.context:
        ctx_parts.append(args.context)
    if not sys.stdin.isatty():
        data = sys.stdin.read().strip()
        if data:
            ctx_parts.append(data)
    context = "\n\n".join(ctx_parts)

    try:
        if backend == "kilo":
            # For kilo backend, ensure model has provider prefix by looking it up in config
            model_name = args.model.strip() or _default_model(backend)
            model = _resolve_kilo_model(model_name)
        else:
            model = args.model.strip() or _default_model(backend)

        root = _git_root()
        diff = _staged_diff(args.amend)
        # Skip binary and generated file sections before any truncation.
        diff = _skip_binary_and_generated(diff)
        status = _status()
        log = _recent_log()
        last_msg = _last_commit_message() if args.amend else ""
        instr = "" if args.no_instructions else _get_instructions(root)
        tok = "" if backend in ("antigravity", "agy") else _token(backend, model)
    except _Error as exc:
        print(f"git-ai-commit: {exc}", file=sys.stderr)
        sys.exit(1)

    amend_no_diff = False
    if not diff.strip():
        if not args.amend:
            print("Nothing staged. Use 'git add' first.", file=sys.stderr)
            sys.exit(0)
        if not last_msg:
            # --amend with nothing staged and no retrievable prior commit
            # message would produce a near-empty prompt; abort early.
            print(
                "Nothing staged and no prior commit message found. "
                "Stage changes or ensure HEAD exists before amending.",
                file=sys.stderr,
            )
            sys.exit(1)
        # No staged changes but we have a prior commit message; rewrite it.
        amend_no_diff = True

    max_diff_chars = _MAX_DIFF_CHARS_DEFAULT
    # Decision on escalation cap based on raw prompt size and resolved model.
    # We compute raw length (pre-truncation) to decide if we should use an escalated cap.
    raw_prompt_size = len(diff) + len(status) + len(log) + len(context) + len(instr)

    # If using kilo, we can escalate the cap for high-context models if the prompt is large.
    if (
        backend == "kilo"
        and not args.model.strip()
        and not (
            os.environ.get("GIT_AI_COMMIT_MODEL") or os.environ.get("GIT_AI_COMMIT_KILO_MODEL")
        )
        and raw_prompt_size > _MAX_DIFF_CHARS_DEFAULT
    ):
        # For the default kilo path (qwen/qwen3-coder-next), we allow the escalated cap.
        max_diff_chars = _MAX_DIFF_CHARS_ESCALATED

    msgs = _build_messages(
        diff,
        status,
        log,
        context,
        root,
        last_msg,
        instr,
        amend_no_diff,
        max_diff_chars=max_diff_chars,
    )

    print(
        f"Generating commit message using {model if model else '<auto>'} via {backend}…",
        file=sys.stderr,
    )

    # For the copilot backend, exchange the OAuth token for a short-lived one.
    # Explicitly resolve a GitHub OAuth token rather than using tok directly —
    # tok may be a non-GitHub key (e.g. GIT_AI_COMMIT_TOKEN set to a LiteLLM
    # API key) that cannot be exchanged for a Copilot token.
    if backend == "copilot":
        try:
            gh_tok = _gh_oauth_token()
            if not gh_tok:
                raise _Error("No GitHub OAuth token found for Copilot backend.")
            tok = _copilot_token(gh_tok)
        except _Error as exc:
            print(f"git-ai-commit: {exc}", file=sys.stderr)
            sys.exit(1)

    try:
        if backend in ("antigravity", "agy"):
            message = _chat_antigravity(model, msgs)
        else:
            message = _chat(tok, api_base, model, msgs, backend)
    except _APIError as primary_err:
        # If GitHub Models fails with an auth or connectivity error, retry via
        # the Copilot API.  This fallback is specific to the github-models
        # backend; kilo and copilot backends don't have a meaningful fallback.
        if backend == "github-models" and primary_err.status in (0, 401, 403):
            print(
                f"GitHub Models API failed ({primary_err}); retrying via Copilot API…",
                file=sys.stderr,
            )
            try:
                # The Copilot token exchange requires a GitHub OAuth token.
                # Re-resolve one explicitly rather than reusing tok, which
                # may be a non-GitHub key (e.g. GIT_AI_COMMIT_TOKEN set to a
                # LiteLLM API key).
                gh_tok = _gh_oauth_token()
                if not gh_tok:
                    raise _Error("No GitHub OAuth token found for Copilot fallback.")
                copilot_tok = _copilot_token(gh_tok)
                message = _chat(copilot_tok, _COPILOT_API_BASE, model, msgs, "copilot")
            except _Error as exc:
                print(f"git-ai-commit: {exc}", file=sys.stderr)
                sys.exit(1)
        else:
            print(f"git-ai-commit: {primary_err}", file=sys.stderr)
            sys.exit(1)
    except _Error as err:
        print(f"git-ai-commit: {err}", file=sys.stderr)
        sys.exit(1)

    if args.dry_run:
        # Write clean message to stdout so it can be captured by scripts.
        # We omit _print_rule(message) above to avoid doubling the output in dry-run mode.
        print(message)
        return

    if args.edit:
        try:
            message = _edit(message)
        except _Error as exc:
            print(f"git-ai-commit: {exc}", file=sys.stderr)
            sys.exit(1)
        if not message.strip():
            print("Empty message — aborting.", file=sys.stderr)
            sys.exit(0)
        _print_rule(message)
    else:
        _print_rule(message)

    if not args.yes and not _confirm("Commit with this message?"):
        print("Aborted.", file=sys.stderr)
        sys.exit(0)

    cmd = ["git", "commit"]
    if args.amend:
        cmd.append("--amend")
    cmd += ["-m", message]
    if extra_git_args:
        cmd += extra_git_args
    try:
        subprocess.run(cmd, check=True)
    except subprocess.CalledProcessError as exc:
        sys.exit(exc.returncode)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\nInterrupted.", file=sys.stderr)
        sys.exit(130)
