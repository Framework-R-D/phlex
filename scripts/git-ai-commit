# No defaults are used unless explicitly set by the user.
# Support deprecated GIT_AI_COMMIT_KILO_* vars as fallback to GIT_AI_COMMIT_*
_KILO_API_ENV = os.environ.get("GIT_AI_COMMIT_API", "").strip()
if not _KILO_API_ENV:
    deprecated = os.environ.get("GIT_AI_COMMIT_KILO_API", "").strip()
    if deprecated:
        import warnings

        warnings.warn(
            "GIT_AI_COMMIT_KILO_API is deprecated; use GIT_AI_COMMIT_API instead",
            DeprecationWarning,
            stacklevel=2,
        )
        _KILO_API_ENV = deprecated
_DEFAULT_KILO_API = _KILO_API_ENV

_KILO_MODEL_ENV = os.environ.get("GIT_AI_COMMIT_MODEL", "").strip()
if not _KILO_MODEL_ENV:
    deprecated = os.environ.get("GIT_AI_COMMIT_KILO_MODEL", "").strip()
    if deprecated:
        import warnings

        warnings.warn(
            "GIT_AI_COMMIT_KILO_MODEL is deprecated; use GIT_AI_COMMIT_MODEL instead",
            DeprecationWarning,
            stacklevel=2,
        )
        _KILO_MODEL_ENV = deprecated
